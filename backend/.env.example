# Copy to .env and fill in real values. NEVER commit .env — it holds live secrets.
#   cp .env.example .env

# SQLAlchemy URL. URL-encode special characters in the password (e.g. # -> %23).
# If your provider's URL includes a `?ssl-mode=REQUIRED` query param (Aiven's
# copy-paste URL does), strip it — PyMySQL doesn't recognize that key. Use
# DB_SSL_CA below for TLS instead.
DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/payroll_db

# Path to a CA cert file. Leave unset for local MySQL (no TLS). Required by
# managed providers that enforce TLS, e.g. Aiven — download their CA cert and
# point this at it (see backend/app/db.py for how it's wired in).
# DB_SSL_CA=./certs/aiven-ca.pem

# JWT signing. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-generated-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated allowed CORS origins (the frontend dev server by default).
CORS_ORIGINS=http://localhost:5173

# Seed user credentials, read by app/seed.py (idempotent; safe to re-run).
DAD_USERNAME=Dad
DAD_EMAIL=dad@example.com
DAD_PASSWORD=replace-me
ADMIN_USERNAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me
